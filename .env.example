# ShowTestCaseLinkedReq Configuration
# Copy this file to .env and set values as needed
# Environment variables override defaults in config.py

# ============================================================================
# API Configuration
# ============================================================================

# Helix ALM API Base URL
HELIX_ALM_BASE_URL=https://10.214.41.6:8443/helix-alm/api/v0/

# API Request timeout in seconds
API_TIMEOUT=30

# SSL Certificate verification (true for production, false for development)
API_VERIFY_SSL=false

# ============================================================================
# Application Configuration
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path (leave empty for console only)
LOG_FILE=

# ============================================================================
# UI Configuration
# ============================================================================

# Main window dimensions
MAIN_WINDOW_WIDTH=1600
MAIN_WINDOW_HEIGHT=900

# Table column widths
TABLE_DESC_COLUMN_WIDTH=350
TABLE_DISC_COLUMN_WIDTH=350

# ============================================================================
# Threading Configuration
# ============================================================================

# Maximum number of worker threads for parallel requirement fetching
MAX_WORKER_THREADS=8

# Minimum number of worker threads
MIN_WORKER_THREADS=1
